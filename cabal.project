    --sha256: sha256-QKKHl/XocxGD7bwAoGe7VaIg9o8x4dA20j3sJOgiTBw=

  source-repository-package
    type: git
    location: https://github.com/palas/mempack.git
    tag: 0211addbbbf51011e5348d3696566eb12ccbef07
