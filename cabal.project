  --sha256: sha256-DR2hxFDNMICcueggBObhi+L5bKeake/Mj4N0078P3SA=
  subdir:
    discrimination-ieee754
    proto-lens-arbitrary
    proto-lens-benchmarks
    proto-lens-discrimination
    proto-lens-optparse
    proto-lens-protobuf-types
    proto-lens-protoc
    proto-lens-runtime
    proto-lens-setup
    proto-lens-tests-dep
    proto-lens-tests
    proto-lens

